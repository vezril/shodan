{
  "name": "shodan",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted WiFi Pineapple-style recon/capture console",
  "workspaces": [
    "contract",
    "web",
    "daemon"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n daemon,web -c blue,green \"npm:dev:daemon\" \"npm:dev:web\"",
    "dev:web": "npm run dev -w @shodan/web",
    "dev:daemon": "npm run dev -w @shodan/daemon",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
